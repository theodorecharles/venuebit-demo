    "@optimizely/optimizely-sdk": "^5.3.4",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.11.5"
  },
  "overrides": {
    "uuid": "^14.0.0"
  }
}
